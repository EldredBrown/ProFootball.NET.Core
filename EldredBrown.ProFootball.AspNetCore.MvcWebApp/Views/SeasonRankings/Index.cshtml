@using EldredBrown.ProFootball.AspNetCore.MvcWebApp.ViewModels.SeasonRankings
@model SeasonRankingsIndexViewModel

@{
    ViewData["Title"] = "Season Rankings";
}

<h1>@ViewData["Title"]</h1>

<form>
    <div class="form-group">
        <label class="col-form-label">Season</label>
        <select onchange="document.location.href=`/SeasonRankings/SetSelectedSeasonYear?SeasonYear=${this.options[this.selectedIndex].value}`;"
                asp-for="SelectedSeasonYear" asp-items="Model.Seasons">
        </select>
    </div>
    <div class="form-group">
        <label class="col-form-label">League</label>
        <select onchange="document.location.href=`/SeasonRankings/SetSelectedLeague?LeagueName=${this.options[this.selectedIndex].value}`;"
                asp-for="SelectedLeague" asp-items="Model.Leagues">
        </select>
    </div>
    <div class="form-group">
        <label class="col-form-label">Type</label>
        <select onchange="document.location.href=`/SeasonRankings/SetSelectedRankingType?RankingType=${this.options[this.selectedIndex].value}`;"
                asp-for="SelectedRankingType" asp-items="Model.RankingTypes">
        </select>
    </div>
</form>

<div class="container">
    <main role="main" class="pb-3">
        @await Html.PartialAsync("_RankingsTable", Model)
    </main>
</div>
