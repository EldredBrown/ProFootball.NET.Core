@using EldredBrown.ProFootball.AspNetCore.MvcWebApp.ViewModels.League
@model LeagueDetailsViewModel

@{
    ViewData["Title"] = "League";
}

<h1>@ViewData["Title"]</h1>

<h4>Details</h4>
<hr />
<div>
    <dl class="row">
        <dt class="col-sm-2">
            <label asp-for="League.ShortName"></label>
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.League.ShortName)
        </dd>
        <dt class="col-sm-2">
            <label asp-for="League.LongName"></label>
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.League.LongName)
        </dd>
        <dt class="col-sm-2">
            <label asp-for="League.FirstSeasonId"></label>
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.League.FirstSeasonId)
        </dd>
        <dt class="col-sm-2">
            <label asp-for="League.LastSeasonId"></label>
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.League.LastSeasonId)
        </dd>
    </dl>
</div>

<div>
    <p>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.League.Id">Edit</a>
    </p>
    <p>
        <a asp-action="Index">Back to List</a>
    </p>
</div>
