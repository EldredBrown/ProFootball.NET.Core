@using EldredBrown.ProFootball.AspNetCore.MvcWebApp.ViewModels.LeagueSeason
@model LeagueSeasonViewModel

@{
    ViewData["Title"] = "Edit League Season";
}

<h1>League Season</h1>

<h4>Edit</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div class="text-danger" asp-validation-summary="ModelOnly"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label class="control-label" asp-for="LeagueName"></label>
                <input class="form-control" asp-for="LeagueName" />
                <span class="text-danger" asp-validation-for="LeagueName"></span>
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="SeasonYear"></label>
                <input class="form-control" asp-for="SeasonYear" />
                <span class="text-danger" asp-validation-for="SeasonYear"></span>
            </div>
            <div class="form-group">
                <p>
                    <button class="btn btn-primary" type="submit">Save</button>
                </p>
            </div>
        </form>
    </div>
</div>

<div>
    <p>
        <a asp-action="Index">Back to List</a>
    </p>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
